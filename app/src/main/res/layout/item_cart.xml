<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorSurfaceVariant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <FrameLayout
            android:id="@+id/layoutCheckmarkContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_margin="4dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorSurfaceVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">
                <ImageView
                    android:id="@+id/ivCartProduct"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_launcher"/>
            </com.google.android.material.card.MaterialCardView>

            <ImageView
                android:id="@+id/ivCheckmark"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|start"
                android:src="@drawable/ic_checkfill"
                app:tint="?attr/colorPrimary"/>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/layoutTextGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/layoutCheckmarkContainer"
            app:layout_constraintEnd_toStartOf="@id/layoutCounterPill">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvCartItemPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹650,"
                    android:textColor="#FF2D55"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvCartItemOriginalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="₹1200"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvCartItemTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Bell Pepper Red x4..."
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvSuggestionBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_discount_pill_light"
                android:backgroundTint="?attr/colorSecondaryContainer"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Suggestion"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:textSize="10sp"
                android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutCounterPill"
            android:layout_width="110dp"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_pill_counter"
            android:backgroundTint="?attr/colorPrimary"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/btnCartDecrease"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_minus1"
                app:tint="#FFFFFF"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/tvCartQuantityValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1 pcs"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:gravity="center"/>

            <ImageButton
                android:id="@+id/btnCartIncrease"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_input_add"
                app:tint="#FFFFFF"
                android:padding="4dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>