<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutBannerLimit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer Name"
                android:textColor="#90A4AE"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <EditText
                android:id="@+id/etCustomerName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_metric_card"
                android:hint="John Doe"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:inputType="textPersonName"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer Mobile"
                android:textColor="#90A4AE"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <EditText
                android:id="@+id/etCustomerMobile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_metric_card"
                android:hint="+91 98765 43210"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:inputType="phone"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer Address"
                android:textColor="#90A4AE"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <EditText
                android:id="@+id/etCustomerAddress"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_metric_card"
                android:hint="Enter explicit delivery address"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:inputType="textPostalAddress"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address Type"
                android:textColor="#90A4AE"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeOffice"
                    android:layout_width="60dp"
                    android:layout_height="48dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_building"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:backgroundTint="#2A83A2"
                    app:cornerRadius="12dp"/>

                <Space android:layout_width="12dp" android:layout_height="wrap_content"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeHome"
                    android:layout_width="60dp"
                    android:layout_height="48dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_home"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="#90A4AE"
                    app:backgroundTint="#FFFFFF"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Mode"
                android:textColor="#90A4AE"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPaymentCash"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:text="Cash"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_map"
                    app:backgroundTint="#2A83A2"
                    app:cornerRadius="12dp"/>

                <Space android:layout_width="12dp" android:layout_height="wrap_content"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPaymentUpi"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:text="UPI"
                    android:textColor="#90A4AE"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_wallet"
                    app:iconTint="#90A4AE"
                    app:backgroundTint="#FFFFFF"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/layoutBannerLimit"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:background="#E1F5FE"
        android:text="Add more items to meet the ₹1500 min order value"
        android:textColor="#2A83A2"
        android:textSize="12sp"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomCheckout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutBottomCheckout"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="#EAF5F8"
        android:paddingHorizontal="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total (without tax)"
                android:textColor="#546E7A"
                android:textSize="12sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvTotalDeliveryPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹12000"
                android:textColor="#FF2D55"
                android:textStyle="bold"
                android:textSize="20sp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckout"
            android:layout_width="180dp"
            android:layout_height="50dp"
            android:text="Checkout  〉"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="#2A83A2"
            app:cornerRadius="25dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>